{
  "ignore": {
    "rules": [
      "knip/*",
      "knip/files",
      "knip/exports",
      "knip/dependencies"
    ],
    "overrides": [
      {
        "files": [
          "__tests__/**"
        ],
        "rules": [
          "react-doctor/async-defer-await",
          "react-doctor/async-await-in-loop",
          "react-doctor/js-combine-iterations",
          "react-doctor/js-flatmap-filter",
          "react-doctor/js-set-map-lookups",
          "react-doctor/rn-prefer-pressable",
          "react-doctor/server-sequential-independent-await",
          "react-hooks-js/globals"
        ]
      },
      {
        "files": [
          "app/_layout.tsx",
          "app/chat/[threadId].tsx",
          "src/context/ChatContext.tsx",
          "src/context/OnboardingContext.tsx"
        ],
        "rules": [
          "react-hooks-js/set-state-in-effect"
        ]
      },
      {
        "files": [
          "src/context/OnboardingContext.tsx"
        ],
        "rules": [
          "react-doctor/jsx-no-constructed-context-values"
        ]
      },
      {
        "files": [
          "package.json"
        ],
        "rules": [
          "react-doctor/expo-lockfile"
        ]
      },
      {
        "files": [
          "src/components/MessageBubble.tsx"
        ],
        "rules": [
          "react-doctor/react-compiler-no-manual-memoization"
        ]
      },
      {
        "files": [
          "src/ui/hooks/useStaggeredList.tsx"
        ],
        "rules": [
          "react-doctor/no-derived-state"
        ]
      },
      {
        "files": [
          "scripts/**",
          "test-dns-simple.js"
        ],
        "rules": [
          "react-doctor/async-await-in-loop",
          "react-doctor/js-combine-iterations",
          "react-doctor/js-flatmap-filter",
          "react-doctor/js-hoist-regexp",
          "react-doctor/js-set-map-lookups",
          "react-doctor/no-dynamic-import-path"
        ]
      },
      {
        "files": [
          "modules/dns-native/**",
          "plugins/**"
        ],
        "rules": [
          "react-doctor/async-await-in-loop",
          "react-doctor/js-tosorted-immutable",
          "react-doctor/server-sequential-independent-await"
        ]
      },
      {
        "files": [
          "app/_layout.tsx",
          "app/chat/[threadId].tsx"
        ],
        "rules": [
          "react-doctor/no-cascading-set-state",
          "react-doctor/rerender-state-only-in-handlers"
        ]
      },
      {
        "files": [
          "src/components/ChatInput.tsx",
          "src/components/onboarding/screens/FirstChatScreen.tsx",
          "src/context/ChatContext.tsx",
          "src/navigation/screens/GlassSettings.tsx"
        ],
        "rules": [
          "react-doctor/no-giant-component",
          "react-doctor/prefer-useReducer",
          "react-doctor/rendering-usetransition-loading"
        ]
      },
      {
        "files": [
          "src/components/ChatInput.tsx",
          "src/components/onboarding/OnboardingContainer.tsx"
        ],
        "rules": [
          "react-doctor/no-render-in-render"
        ]
      },
      {
        "files": [
          "src/components/ErrorBoundary.tsx",
          "src/components/glass/GlassBottomSheet.tsx",
          "src/components/glass/GlassTabBar.tsx",
          "src/navigation/screens/GlassSettings.tsx"
        ],
        "rules": [
          "react-doctor/rn-prefer-pressable"
        ]
      },
      {
        "files": [
          "src/components/glass/GlassBottomSheet.tsx",
          "src/components/glass/GlassForm.tsx",
          "src/components/onboarding/OnboardingProgress.tsx"
        ],
        "rules": [
          "react-doctor/no-array-index-as-key"
        ]
      },
      {
        "files": [
          "src/components/DNSLogViewer.tsx",
          "src/components/ui/LiquidGlassTextInput.tsx",
          "src/navigation/screens/GlassChatList.tsx",
          "src/navigation/screens/GlassSettings.tsx",
          "src/navigation/screens/Logs.tsx"
        ],
        "rules": [
          "react-doctor/rerender-state-only-in-handlers"
        ]
      },
      {
        "files": [
          "src/components/LiquidGlassWrapper.tsx",
          "src/context/SettingsContext.tsx"
        ],
        "rules": [
          "react-doctor/no-cascading-set-state"
        ]
      },
      {
        "files": [
          "src/components/onboarding/screens/DNSMagicScreen.tsx",
          "src/components/onboarding/screens/NetworkSetupScreen.tsx",
          "src/services/dnsService.ts"
        ],
        "rules": [
          "react-doctor/async-await-in-loop"
        ]
      },
      {
        "files": [
          "src/components/onboarding/screens/FirstChatScreen.tsx",
          "src/components/onboarding/screens/NetworkSetupScreen.tsx",
          "src/services/dnsLogService.ts"
        ],
        "rules": [
          "react-doctor/async-defer-await"
        ]
      },
      {
        "files": [
          "src/navigation/screens/GlassSettings.tsx",
          "src/services/dnsLogService.ts"
        ],
        "rules": [
          "react-doctor/async-parallel"
        ]
      },
      {
        "files": [
          "src/services/dnsService.ts",
          "src/services/storageService.ts"
        ],
        "rules": [
          "react-doctor/js-set-map-lookups"
        ]
      },
      {
        "files": [
          "src/services/dnsWire.ts",
          "src/utils/androidStartupDiagnostics.ts"
        ],
        "rules": [
          "react-doctor/js-combine-iterations"
        ]
      },
      {
        "files": [
          "src/services/ShareService.ts"
        ],
        "rules": [
          "react-doctor/js-hoist-intl"
        ]
      },
      {
        "files": [
          "src/components/onboarding/screens/NetworkSetupScreen.tsx",
          "src/components/ui/Toast.tsx"
        ],
        "rules": [
          "react-doctor/prefer-use-effect-event"
        ]
      },
      {
        "files": [
          "src/components/onboarding/screens/NetworkSetupScreen.tsx"
        ],
        "rules": [
          "react-doctor/prefer-useReducer"
        ]
      },
      {
        "files": [
          "src/components/onboarding/screens/WelcomeScreen.tsx"
        ],
        "rules": [
          "react-doctor/rn-prefer-expo-image"
        ]
      },
      {
        "files": [
          "src/components/glass/GlassForm.tsx"
        ],
        "rules": [
          "react-doctor/rn-prefer-content-inset-adjustment"
        ]
      },
      {
        "files": [
          "src/components/onboarding/screens/FirstChatScreen.tsx"
        ],
        "rules": [
          "react-doctor/rn-no-scrollview-mapped-list"
        ]
      },
      {
        "files": [
          "src/components/onboarding/OnboardingProgress.tsx"
        ],
        "rules": [
          "react-doctor/rn-prefer-reanimated"
        ]
      },
      {
        "files": [
          "src/components/PressableRipple.tsx"
        ],
        "rules": [
          "react-doctor/no-react19-deprecated-apis"
        ]
      },
      {
        "files": [
          "src/components/ui/Toast.tsx"
        ],
        "rules": [
          "react-doctor/no-derived-useState",
          "react-doctor/no-z-index-9999"
        ]
      },
      {
        "files": [
          "src/components/ui/LiquidGlassTextInput.tsx"
        ],
        "rules": [
          "react-doctor/no-generic-handler-names"
        ]
      },
      {
        "files": [
          "src/navigation/screens/GlassChatList.tsx",
          "src/navigation/screens/GlassSettings.tsx",
          "src/navigation/screens/Logs.tsx"
        ],
        "rules": [
          "react-doctor/no-barrel-import"
        ]
      },
      {
        "files": [
          ".omc/**"
        ],
        "rules": [
          "deslop/unused-file",
          "deslop/unused-export",
          "react-doctor/js-combine-iterations",
          "react-doctor/unused-file",
          "react-doctor/unused-export",
          "knip/*",
          "unused-file",
          "unused-export"
        ]
      },
      {
        "files": [
          "docs/GUIDELINES-REF/**",
          "plugins/**",
          "test-dns-simple.js"
        ],
        "rules": [
          "deslop/unused-file",
          "deslop/unused-export",
          "deslop/unused-dev-dependency",
          "react-doctor/unused-file",
          "react-doctor/unused-export",
          "react-doctor/unused-dev-dependency",
          "knip/*",
          "unused-file",
          "unused-export",
          "unused-dev-dependency"
        ]
      },
      {
        "files": [
          "app/**",
          "src/**"
        ],
        "rules": [
          "deslop/unused-export",
          "deslop/unused-file",
          "react-doctor/exhaustive-deps",
          "react-doctor/effect-needs-cleanup",
          "react-doctor/no-array-index-key",
          "react-doctor/no-chain-state-updates",
          "react-doctor/no-event-handler",
          "react-doctor/no-initialize-state",
          "react-doctor/no-multi-comp",
          "react-doctor/no-pass-data-to-parent",
          "react-doctor/only-export-components",
          "react-doctor/unused-export",
          "react-doctor/unused-file",
          "knip/*",
          "unused-export",
          "unused-file"
        ]
      },
      {
        "files": [
          "modules/dns-native/constants.ts",
          "package.json"
        ],
        "rules": [
          "deslop/unused-export",
          "deslop/unused-dev-dependency",
          "react-doctor/unused-export",
          "react-doctor/unused-dev-dependency",
          "knip/*",
          "unused-export",
          "unused-dev-dependency"
        ]
      }
    ]
  },
  "failOn": "error"
}
