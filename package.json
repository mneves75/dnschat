{
  "name": "chat-dns",
  "version": "4.0.29",
  "description": "DNSChat - A React Native chat app using DNS TXT queries",
  "main": "entry.tsx",
  "author": "DNSChat contributors",
  "license": "MIT",
  "homepage": "https://github.com/mneves75/dnschat",
  "repository": {
    "type": "git",
    "url": "https://github.com/mneves75/dnschat.git"
  },
  "bugs": {
    "url": "https://github.com/mneves75/dnschat/issues"
  },
  "keywords": [
    "dns",
    "chat",
    "react-native",
    "expo",
    "llm",
    "dns-txt"
  ],
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "node scripts/run-android.js",
    "android:java24": "expo run:android",
    "ios": "expo run:ios",
    "sync-versions": "node scripts/sync-versions.js",
    "sync-versions:dry": "node scripts/sync-versions.js --dry-run",
    "fix-pods": "scripts/fix-cocoapods.sh",
    "clean-ios": "cd ios && rm -rf Pods/ build/ && pod install",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --runInBand",
    "e2e:axe": "node scripts/e2e-axe.js",
    "e2e:axe:doctor": "node scripts/e2e-axe.js --doctor",
    "e2e:axe:release": "node scripts/e2e-axe.js --create-simulator --delete-created-simulator --build-release --reset-app",
    "test:android": "jest --runInBand --testPathPattern=androidStartupDiagnostics",
    "verify:android": "node scripts/verify-android-setup.js",
    "verify:android-16kb": "node scripts/check-android-16kb.js",
    "verify:sdk-alignment": "node scripts/verify-sdk-alignment.js",
    "verify:typed-routes": "node scripts/verify-typed-routes.js",
    "verify:expo-doctor": "RUBYOPT=-rlogger npx expo-doctor",
    "verify:react-compiler": "react-compiler-healthcheck",
    "verify:public-redaction": "node scripts/check-public-redaction.js",
    "verify:security": "bun audit && gitleaks detect --source . --redact --no-banner --config .gitleaks.toml",
    "verify:all": "bun run verify:public-redaction && bun run verify:security && bun run verify:expo-doctor && bun run verify:sdk-alignment && bun run verify:typed-routes && bun run typecheck && bun run verify:dnsresolver-sync && bun run verify:ios-pods && bun run verify:react-compiler && bun run verify:android && bun run verify:android-16kb && bun run lint && bun run test",
    "verify:dnsresolver-sync": "node scripts/verify-dnsresolver-sync.js",
    "lint:ast-grep": "node scripts/run-ast-grep.js --config project-rules/astgrep-liquid-glass.yml",
    "lint": "node scripts/run-ast-grep.js --config project-rules/astgrep-liquid-glass.yml",
    "dns:harness:build": "tsc -p scripts/tsconfig.harness.json",
    "dns:harness": "bun run dns:harness:build && node scripts/dist/run-dns-harness.js",
    "verify:ios-pods": "node scripts/verify-ios-pods-sync.js",
    "prepare": "node scripts/install-git-hooks.js",
    "postinstall": "node scripts/postinstall-ios-pods.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "@expo/ui": "~56.0.16",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.14.2",
    "date-fns": "^4.1.0",
    "dns-packet": "^5.6.1",
    "expo": "~56.0.9",
    "expo-asset": "~56.0.16",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-device-info": "^14.0.4",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-tcp-socket": "6.4.1",
    "react-native-udp": "4.1.7",
    "react-native-uuid": "^2.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.40.3",
    "@types/dns-packet": "^5.6.5",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.0.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "jest": "^29.7.0",
    "react-compiler-healthcheck": "1.0.0",
    "react-test-renderer": "19.2.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "@xmldom/xmldom": ">=0.8.13",
    "brace-expansion": "5.0.6",
    "handlebars": ">=4.7.9",
    "markdown-it": ">=12.3.2",
    "node-forge": ">=1.4.0",
    "postcss": ">=8.5.10",
    "shell-quote": ">=1.8.4",
    "uuid": "11.1.1",
    "ws": "8.20.1",
    "yaml": ">=2.8.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-udp",
          "react-native-tcp-socket",
          "@dnschat/dns-native",
          "expo-modules-jsi"
        ],
        "listUnknownPackages": true
      },
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "private": true
}
