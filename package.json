{
  "name": "chat-dns",
  "version": "2.1.2",
  "description": "DNSChat - A React Native chat app using DNS TXT queries",
  "main": "index.tsx",
  "author": "mvneves",
  "license": "MIT",
  "homepage": "https://github.com/mneves75/dnschat",
  "scripts": {
    "start": "expo start --dev-client",
    "web": "expo start --web",
    "android": "JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home PATH=/opt/homebrew/opt/openjdk@17/bin:$PATH expo run:android",
    "android:java24": "expo run:android",
    "ios": "expo run:ios",
    "sync-versions": "node scripts/sync-versions.js",
    "sync-versions:dry": "node scripts/sync-versions.js --dry-run",
    "fix-pods": "scripts/fix-cocoapods.sh",
    "clean-ios": "cd ios && rm -rf Pods/ Podfile.lock build/ && pod install"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.1.1",
    "@react-navigation/elements": "^2.2.3",
    "@react-navigation/native": "^7.0.12",
    "@react-navigation/native-stack": "^7.1.13",
    "@types/dns-packet": "^5.6.5",
    "date-fns": "^4.1.0",
    "dns-packet": "^5.6.1",
    "expo": "54.0.0-preview.7",
    "expo-asset": "~12.0.2",
    "expo-build-properties": "~1.0.4",
    "expo-dev-client": "~6.0.4",
    "expo-splash-screen": "~31.0.4",
    "expo-system-ui": "~6.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.0",
    "react-native-bottom-tabs": "^0.10.0",
    "react-native-device-info": "^14.0.4",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-paper": "^5.14.1",
    "react-native-reanimated": "~4.0.2",
    "react-native-safe-area-context": "5.6.1",
    "react-native-screens": "~4.15.0",
    "react-native-svg": "15.12.1",
    "react-native-tcp-socket": "^6.3.0",
    "react-native-udp": "^4.1.7",
    "react-native-uuid": "^2.0.3",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "markdown-it": "^14.1.0"
  },
  "private": true
}
