<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- 
    Material Design 3 Theme Configuration for DNSChat
    
    Features:
    - Material 3 color system integration
    - Dynamic color support (Android 12+)
    - Edge-to-edge display support
    - Proper theming for React Native components
  -->
  
  <!-- Main App Theme using Material 3 -->
  <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
    <!-- Material 3 Color System -->
    <item name="colorPrimary">@color/md_theme_light_primary</item>
    <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
    <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
    <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
    
    <item name="colorSecondary">@color/md_theme_light_secondary</item>
    <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
    <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
    <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
    
    <item name="colorTertiary">@color/md_theme_light_tertiary</item>
    <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
    <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
    <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
    
    <item name="android:colorBackground">@color/md_theme_light_background</item>
    <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
    <item name="colorSurface">@color/md_theme_light_surface</item>
    <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
    <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
    <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
    
    <item name="colorError">@color/md_theme_light_error</item>
    <item name="colorOnError">@color/md_theme_light_onError</item>
    <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
    <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
    
    <item name="colorOutline">@color/md_theme_light_outline</item>
    <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>
    <item name="colorSurfaceTint">@color/md_theme_light_surfaceTint</item>
    
    <!-- React Native specific styling -->
    <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
    
    <!-- Edge-to-edge window configuration -->
    <item name="android:navigationBarColor">@android:color/transparent</item>
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    
    <!-- Enable dynamic colors on Android 12+ -->
    <item name="dynamicColorThemeOverlay" tools:targetApi="31">@style/ThemeOverlay.Material3.DynamicColors.DayNight</item>
  </style>
  
  <!-- Material 3 Splash Screen Theme -->
  <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen">
    <item name="windowSplashScreenBackground">@color/splashscreen_background</item>
    <item name="windowSplashScreenAnimatedIcon">@drawable/splashscreen_logo</item>
    <item name="postSplashScreenTheme">@style/AppTheme</item>
  </style>
  
  <!-- Material 3 Glass Surface Style (for enhanced components) -->
  <style name="MaterialGlassSurface">
    <item name="android:background">@color/glass_surface_light</item>
    <item name="android:elevation">8dp</item>
    <item name="cornerFamily">rounded</item>
    <item name="cornerSize">12dp</item>
  </style>
  
  <!-- Material 3 Card Style -->
  <style name="MaterialCard" parent="Widget.Material3.CardView.Elevated">
    <item name="cardCornerRadius">16dp</item>
    <item name="cardElevation">2dp</item>
    <item name="cardBackgroundColor">@color/md_theme_light_surface</item>
    <item name="strokeColor">@color/md_theme_light_outline</item>
    <item name="strokeWidth">0dp</item>
  </style>
  
  <!-- Material 3 Button Styles -->
  <style name="MaterialButton.Primary" parent="Widget.Material3.Button">
    <item name="backgroundTint">@color/md_theme_light_primary</item>
    <item name="android:textColor">@color/md_theme_light_onPrimary</item>
    <item name="cornerRadius">8dp</item>
  </style>
  
  <style name="MaterialButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
    <item name="strokeColor">@color/md_theme_light_outline</item>
    <item name="android:textColor">@color/md_theme_light_primary</item>
    <item name="cornerRadius">8dp</item>
  </style>
</resources>